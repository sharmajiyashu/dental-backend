{
  "name": "dental-backend",
  "version": "1.0.0",
  "description": "Healthy Life Dental and Personal Tracker Backend",
  "main": "dist/index.js",
  "scripts": {
    "seed": "ts-node ./src/seeders/runSeeders.ts",
    "build": "rimraf dist && tsc",
    "dev": "nodemon --watch src/**/*.ts --exec ts-node --files src/index.ts",
    "start": "npm run build && node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.21",
    "mongoose": "^7.3.1",
    "multer": "^2.2.0",
    "nodemailer": "^6.9.3",
    "reflect-metadata": "^0.1.13",
    "streamifier": "^0.1.1",
    "typedi": "^0.10.0",
    "winston": "^3.9.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/lodash": "^4.14.195",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.8",
    "@types/streamifier": "^0.1.2",
    "nodemon": "^2.0.22",
    "rimraf": "^5.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
